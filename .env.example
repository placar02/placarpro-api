# =============================================================================
# PLACARPRO-API - VARIÁVEIS DE AMBIENTE
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA comita arquivos .env contendo valores reais no repositório.
# =============================================================================

# =============================================================================
# 1. CONFIGURAÇÃO DO SERVIDOR
# =============================================================================

# Ambiente de execução
# Valores: development | production
NODE_ENV=production

# Porta onde o servidor Express escuta
# Em produção (Render), a porta é fornecida pela plataforma via PROCESS_ENV.PORT
PORT=3000

# =============================================================================
# 2. URLs PÚBLICAS
# =============================================================================

# URL base da API (sem trailing slash)
# Produção: URL do seu backend no Render
PUBLIC_API_URL=https://seu-backend.onrender.com

# URL do frontend (sem trailing slash)
# Produção: URL do seu frontend na Vercel
FRONTEND_URL=https://seu-frontend.vercel.app

# Domínios permitidos para CORS (separados por vírgula, sem espaços)
# Inclua domains localhost para desenvolvimento
CORS_ORIGINS=https://seu-frontend.vercel.app,http://localhost:5175,http://localhost:3000

# =============================================================================
# 3. BANCO DE DADOS POSTGRESQL
# =============================================================================

# String de conexão completa do PostgreSQL
# Formato: postgresql://usuario:senha@host:porta/database
# Produção: Use o valor fornecido pelo Render (neon/layerjet/etc)
# Exemplo: postgresql://usuario:senha@db-host.render.com:5432/placarpro
DATABASE_URL=postgresql://usuario:senha@host:5432/database

# Habilita conexão SSL com o banco
# ATENÇÃO: Sempre TRUE em produção
DB_SSL=true

# =============================================================================
# 4. AUTENTICAÇÃO E SESSÕES
# =============================================================================

# Segredo para assinar tokens JWT
# IMPORTANTE: Gere um segredo forte (mínimo 32 caracteres, idealmente 64+)
# Use: openssl rand -base64 64 (Linux/Mac) ou gerador online
# NUNCA use este valor padrão em produção
JWT_SECRET=SEU_SEGREDO_JWT_MUITO_FORTE_AQUI

# Tempo de expiração da sessão em horas
# Padrão: 24 (1 dia)
AUTH_SESSION_HOURS=24

# Intervalo em minutos para "tocar" a sessão (renovar expiração)
# Padrão: 5
AUTH_SESSION_TOUCH_INTERVAL_MINUTES=5

# Tempo em minutos para expiração do token de reset de senha
# Padrão: 30
PASSWORD_RESET_TTL_MINUTES=30

# Nome do cookie de sessão
# Padrão: placarpro_session
AUTH_COOKIE_NAME=placarpro_session

# SameSite attribute do cookie
# - 'lax': Padrão, funciona com subnavegação (links do email)
# - 'strict': Mais seguro, mas pode não funcionar em alguns casos
# - 'none': Para cross-site, requer HTTPS
# Em produção com frontend e API em domínios diferentes, use 'none' com HTTPS
AUTH_COOKIE_SAME_SITE=none

# =============================================================================
# 5. RESET DE SENHA (OPCIONAL)
# =============================================================================

# Webhook para envio de emails de reset de senha
# Recebe payload JSON: { recipient, resetUrl, expiresInMinutes }
# Configure via Zapier, Make, ou seu próprio serviço de email
# Deixe vazio se não usar reset de senha
PASSWORD_RESET_WEBHOOK_URL=

# NÃO ALTERE ESTA OPÇÃO - Para testes locais apenas
# Mantenha FALSE em produção
EXPOSE_PASSWORD_RESET_TOKEN=false

# =============================================================================
# 6. PAGAMENTOS - MERCADOPAGO
# =============================================================================

# Access Token do MercadoPago (obtenha em: https://www.mercadopago.com.br/developers)
# PRODUÇÃO: Use o Access Token de Produção
# TESTE: Use o Access Token de Teste
MERCADOPAGO_ACCESS_TOKEN=

# Public Key do MercadoPago (para frontend)
MERCADOPAGO_PUBLIC_KEY=

# Email do comprador de testes (opcional)
# Usado para aprovar automaticamente pagamentos de teste
MERCADOPAGO_TEST_BUYER_EMAIL=

# Secret para verificar webhook do MercadoPago
MERCADOPAGO_WEBHOOK_SECRET=

# Tolerância em segundos para aceitar webhooks atrasados
# Padrão: 300 (5 minutos)
MERCADOPAGO_WEBHOOK_TOLERANCE_SECONDS=300

# URL do webhook (preenchido automaticamente pelo Render na maioria dos casos)
# Mantenha vazio para produção, ou configure manualmente
MERCADOPAGO_WEBHOOK_URL=https://seu-backend.onrender.com/api/payments/webhook

# ID externo do produto/serviço no MercadoPago
MERCADOPAGO_PREMIUM_PRODUCT_EXTERNAL_ID=placarpro-premium

# Descrição do produto premium
MERCADOPAGO_PREMIUM_PRODUCT_DESCRIPTION=Acesso premium ao PlacarPro

# Permite aprovação automática de pagamentos de teste
# ATENÇÃO: FALSE em produção
ALLOW_PAYMENT_TEST_APPROVAL=false

# =============================================================================
# 7. PLANOS E PREÇOS
# =============================================================================

# Preço do plano premium em centavos
# Exemplo: 2000 = R$ 20,00
PREMIUM_PLAN_PRICE_CENTS=2000

# =============================================================================
# 8. CONFIGURAÇÕES DO SISTEMA DE ANÁLISE
# =============================================================================

# Provedor principal de dados esportivos
# Padrão: sofascore
SCORES_PROVIDER=sofascore

# Versão do cache de análise diária
# Altere ao invalidar cache ou atualizar algoritmos
DAILY_PICK_CACHE_VERSION=v26

# Modo somente leitura (desliga geração automática)
# TRUE: API não gera análises, apenas serve dados cacheados
# FALSE: Permite geração sob demanda (requer scraper conectado)
DAILY_PICK_READ_ONLY=true

# Habilita scheduler interno para análise diária
# ATENÇÃO: Desligado em produção (use worker externo)
DAILY_PICK_SCHEDULER_ENABLED=false

# Habilita geração de análise sob demanda
# Requer DAILY_PICK_READ_ONLY=false
DAILY_PICK_ON_DEMAND_ENABLED=false

# Habilita publicação automática de análises
# ATENÇÃO: Desligado em produção
DAILY_PICK_PUBLISHER_ENABLED=false

# Habilita enriquecimento de odds
DAILY_PICK_REQUIRE_REAL_ODDS=true

# Valor mínimo de Expected Value para recomendar entrada
# Padrão: 0.05 (5%)
DAILY_PICK_MIN_EXPECTED_VALUE=0.05

# Versão da política de decisão
DAILY_PICK_POLICY_VERSION=accuracy-v1

# =============================================================================
# 9. CALIBRAÇÃO E ANÁLISE DE IA
# =============================================================================

# Tamanho mínimo da amostra para calibragem
# Padrão: 30
ANALYSIS_CALIBRATION_MIN_SAMPLE=30

# Tamanho mínimo da amostra para pesos
# Padrão: 100
ANALYSIS_WEIGHT_MIN_SAMPLE=100

# Habilita monitoramento de análises
ANALYSIS_MONITOR_ENABLED=true

# Intervalo de monitoramento em milissegundos
# Padrão: 300000 (5 minutos)
ANALYSIS_MONITOR_INTERVAL_MS=300000

# Idade máxima do worker em horas
ANALYSIS_WORKER_MAX_AGE_HOURS=30

# Idade máxima de publicação em horas
ANALYSIS_PUBLICATION_MAX_AGE_HOURS=30

# Alerta quandopredições pendentes ultrapassam este limite
ANALYSIS_OVERDUE_PREDICTIONS_ALERT=20

# Máximo de dias para análise manual à frente
DAILY_PICK_MANUAL_MAX_DAYS_AHEAD=14

# =============================================================================
# 10. CONFIGURAÇÕES DE WORKER (PARA AMBIENTE LOCAL)
# =============================================================================
# As variáveis abaixo são usadas apenas na máquina que executa o worker local.
# NAO configure no Render/produção.

# URL da API onde publicar análises (API pública)
# DAILY_PICK_PUBLISH_URL=http://localhost:3000

# Segredo para publicar análises (deve ser igual ao DAILY_PICK_PUBLISH_SECRET da API pública)
# DAILY_PICK_PUBLISH_SECRET=seu_segredo_de_publicacao

# URL base do scraper (para heartbeat)
# PLACARPRO_API_URL=http://localhost:3001

# Segredo interno para comunicação scraper <-> API
# SCRAPER_INTERNAL_SECRET=seu_segredo_interno

# Modos de publicação (prelive, live)
# DAILY_PICK_PUBLISH_MODES=prelive

# Timeout para análise de uma partida (ms)
# DAILY_PICK_ANALYSIS_TIMEOUT_MS=120000

# Concorrência de análise
# DAILY_PICK_ANALYSIS_CONCURRENCY=1

# Máximo de candidatos por análise
# DAILY_PICK_MAX_CANDIDATES=15

# Timeout para análise completa (ms)
# DAILY_PICK_FULL_DAILY_TIMEOUT_MS=360000

# Timeout para proxy de análise (ms)
# ANALYSIS_PROXY_TIMEOUT_MS=360000

# Tamanho do batch para settlement
# ANALYSIS_SETTLEMENT_BATCH_SIZE=50

# =============================================================================
# 11. WEBHOOKS E ALERTAS (OPCIONAL)
# =============================================================================

# Webhook para alertas de análise (Slack, Teams, etc)
# Recebe payload quando nova análise é publicada ou reativada
# ANALISIS_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# =============================================================================
# 12. CONFIGURAÇÕES DE TESTE DE CARGA (DESENVOLVIMENTO)
# =============================================================================
# NAO habilite em produção

# URL base para teste de carga
# LOAD_TEST_BASE_URL=http://localhost:3000

# Path para teste
# LOAD_TEST_PATH=/api/health

# Número de requisições
# LOAD_TEST_REQUESTS=100

# Concorrência
# LOAD_TEST_CONCURRENCY=10

# Timeout em ms
# LOAD_TEST_TIMEOUT_MS=10000

# Taxa máxima de erro aceitável
# LOAD_TEST_MAX_ERROR_RATE=0.01

# Idade máxima do heartbeat em horas
# WORKER_HEARTBEAT_MAX_AGE_HOURS=36
