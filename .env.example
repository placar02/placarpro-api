# NODE_ENV=production
# PORT=3000

# # Frontend publico autorizado no CORS
# FRONTEND_URL=https://seu-frontend.com
# CORS_ORIGINS=https://seu-frontend.com

# # API do scraper
# PLACARPRO_API_URL=https://sua-api-scraper.com
# Mantenha false para analisar apenas dados esportivos, sem aguardar odds.
# ENABLE_ODDS_ENRICHMENT=false

# # Banco PostgreSQL
# DATABASE_URL=postgresql://usuario:senha@host:5432/database
# DB_SSL=true

# # Auth
# JWT_SECRET=troque-por-um-segredo-grande

# # Mercado Pago
# MERCADOPAGO_ACCESS_TOKEN=
# MERCADOPAGO_PUBLIC_KEY=
# # Em credenciais TEST-, use aqui o email de uma conta compradora de teste criada no Mercado Pago.
# MERCADOPAGO_TEST_BUYER_EMAIL=
# MERCADOPAGO_WEBHOOK_SECRET=
# MERCADOPAGO_WEBHOOK_URL=https://seu-backend.com/api/payments/webhook
# PUBLIC_API_URL=https://seu-backend.com
# MERCADOPAGO_PREMIUM_PRODUCT_EXTERNAL_ID=placarpro-premium
# MERCADOPAGO_PREMIUM_PRODUCT_DESCRIPTION=Acesso premium ao PlacarPro
# ALLOW_PAYMENT_TEST_APPROVAL=false

# # Plano
# PREMIUM_PLAN_PRICE_CENTS=4990

# # Cache/analise
# DAILY_PICK_TIMEZONE=America/Sao_Paulo
# DAILY_PICK_ANALYSIS_TIMEOUT_MS=30000
# DAILY_PICK_CACHE_TTL_MS=900000
