# Runtime
NODE_ENV=production
PORT=3000

# URLs publicas
PUBLIC_API_URL=https://seu-backend.onrender.com
FRONTEND_URL=https://seu-frontend.vercel.app
CORS_ORIGINS=https://seu-frontend.vercel.app

# Banco PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/database
DB_SSL=true

# Auth
JWT_SECRET=troque-por-um-segredo-grande
AUTH_SESSION_HOURS=24
AUTH_SESSION_TOUCH_INTERVAL_MINUTES=5
PASSWORD_RESET_TTL_MINUTES=30
# Webhook interno do seu provedor/automacao de email. Recebe recipient, resetUrl e expiresInMinutes.
PASSWORD_RESET_WEBHOOK_URL=
# Somente desenvolvimento/testes locais; nunca habilite em producao.
EXPOSE_PASSWORD_RESET_TOKEN=false
AUTH_COOKIE_NAME=placarpro_session
# Em producao com frontend e API em dominios diferentes, mantenha none.
AUTH_COOKIE_SAME_SITE=none

# Plano unico mensal
PREMIUM_PLAN_PRICE_CENTS=2000

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_TEST_BUYER_EMAIL=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_WEBHOOK_TOLERANCE_SECONDS=300
MERCADOPAGO_WEBHOOK_URL=https://seu-backend.onrender.com/api/payments/webhook
MERCADOPAGO_PREMIUM_PRODUCT_EXTERNAL_ID=placarpro-premium
MERCADOPAGO_PREMIUM_PRODUCT_DESCRIPTION=Acesso premium ao PlacarPro
ALLOW_PAYMENT_TEST_APPROVAL=false

# Analise diaria no Render/API publica
# Importante: em producao a API nao deve chamar scraper/IA pelo dashboard.
SCORES_PROVIDER=sofascore
DAILY_PICK_CACHE_VERSION=v26
DAILY_PICK_READ_ONLY=true
DAILY_PICK_SCHEDULER_ENABLED=false
DAILY_PICK_ON_DEMAND_ENABLED=false
DAILY_PICK_PUBLISHER_ENABLED=false
ENABLE_ODDS_ENRICHMENT=false
DAILY_PICK_REQUIRE_REAL_ODDS=true
DAILY_PICK_MIN_EXPECTED_VALUE=0.05
DAILY_PICK_POLICY_VERSION=accuracy-v1
ANALYSIS_CALIBRATION_MIN_SAMPLE=30
ANALYSIS_WEIGHT_MIN_SAMPLE=100
ANALYSIS_MONITOR_ENABLED=true
ANALYSIS_MONITOR_INTERVAL_MS=300000
ANALYSIS_WORKER_MAX_AGE_HOURS=30
ANALYSIS_PUBLICATION_MAX_AGE_HOURS=30
ANALYSIS_OVERDUE_PREDICTIONS_ALERT=20
DAILY_PICK_MANUAL_MAX_DAYS_AHEAD=14
# Webhook opcional para alertas novos/reativados (Slack, Teams ou automacao propria)
ANALYSIS_ALERT_WEBHOOK_URL=

# Teste de carga seguro (padrao: /api/health)
LOAD_TEST_BASE_URL=http://localhost:3000
LOAD_TEST_PATH=/api/health
LOAD_TEST_REQUESTS=100
LOAD_TEST_CONCURRENCY=10
LOAD_TEST_TIMEOUT_MS=10000
LOAD_TEST_MAX_ERROR_RATE=0.01
WORKER_HEARTBEAT_MAX_AGE_HOURS=36

# Use somente na maquina publicadora local
# PLACARPRO_API_URL=http://localhost:3001
# SCRAPER_INTERNAL_SECRET=mesmo-segredo-configurado-no-scraper
# DAILY_PICK_READ_ONLY=false
# DAILY_PICK_PUBLISHER_ENABLED=true
# DAILY_PICK_PUBLISH_SECRET=troque-por-um-segredo-grande
# DAILY_PICK_PUBLISH_URL=http://localhost:3000
# DAILY_PICK_HEARTBEAT_URL=https://seu-backend.onrender.com
# DAILY_PICK_PUBLISH_MODES=prelive
# DAILY_PICK_ANALYSIS_TIMEOUT_MS=120000
# DAILY_PICK_ANALYSIS_CONCURRENCY=1
# DAILY_PICK_MAX_CANDIDATES=15
# DAILY_PICK_FULL_DAILY_TIMEOUT_MS=360000
# ANALYSIS_PROXY_TIMEOUT_MS=360000

# Na API publica read-only, configure o mesmo segredo do worker para heartbeat e consultas operacionais.
# DAILY_PICK_PUBLISH_SECRET=troque-por-um-segredo-grande
# ANALYSIS_SETTLEMENT_BATCH_SIZE=50
